<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>CV Generator</display-name>

    <!-- Welcome list: redirect to wizard step 1 -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- Step 1: Personal Information (Etat Civil) -->
    <servlet>
        <servlet-name>EtatCivilServlet</servlet-name>
        <servlet-class>controller.EtatCivilServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>EtatCivilServlet</servlet-name>
        <url-pattern>/etatcivil</url-pattern>
    </servlet-mapping>

    <!-- Step 2: Education (Formation) -->
    <servlet>
        <servlet-name>FormationServlet</servlet-name>
        <servlet-class>controller.FormationServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>FormationServlet</servlet-name>
        <url-pattern>/formation</url-pattern>
    </servlet-mapping>

    <!-- Step 3: Professional Experience -->
    <servlet>
        <servlet-name>ExperienceServlet</servlet-name>
        <servlet-class>controller.ExperienceServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ExperienceServlet</servlet-name>
        <url-pattern>/experience</url-pattern>
    </servlet-mapping>

    <!-- Step 4: Skills & Hobbies -->
    <servlet>
        <servlet-name>SkillsServlet</servlet-name>
        <servlet-class>controller.SkillsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SkillsServlet</servlet-name>
        <url-pattern>/skills</url-pattern>
    </servlet-mapping>

    <!-- CV Preview -->
    <servlet>
        <servlet-name>CvPreviewServlet</servlet-name>
        <servlet-class>controller.CvPreviewServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CvPreviewServlet</servlet-name>
        <url-pattern>/cv</url-pattern>
    </servlet-mapping>

    <!-- Session timeout: 30 minutes -->
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>
</web-app>
